#!/bin/bash

# Version Control
VERSION="1.6.0"

# Color Codes for Terminal UI
PURPLE='\033[1;35m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
RESET='\033[0m'

# Configuration persistence settings
CONFIG_DIR="$HOME/.config/rlcli"
CONFIG_FILE="$CONFIG_DIR/config"

# Out-of-the-box Hardcoded Fallbacks
DEFAULT_LOC="~/projects"
DEFAULT_WIDTH=1280
DEFAULT_HEIGHT=720
DEFAULT_FPS=60
DEFAULT_LANG="cpp"

# Read user-defined configuration if it exists
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# Helper function to check system dependencies gracefully
check_dependency() {
    if ! command -v "$1" &> /dev/null; then
        echo -e "${RED}  ✗ Error: Required dependency '$1' is missing.${RESET}"
        echo -e "    Please install it using your system package manager before continuing."
        exit 1
    fi
}

case "$1" in
    new)
        echo ""
        echo -e "${PURPLE}  ██████╗  █████╗ ██╗   ██╗██╗     ██╗██████╗ ${RESET}"
        echo -e "${PURPLE}  ██╔══██╗██╔══██╗╚██╗ ██╔╝██║     ██║██╔══██╗${RESET}"
        echo -e "${PURPLE}  ██████╔╝███████║ ╚████╔╝ ██║     ██║██████╔╝${RESET}"
        echo -e "${PURPLE}  ██╔══██╗██╔══██║  ╚██╔╝  ██║     ██║██╔══██╗${RESET}"
        echo -e "${PURPLE}  ██║  ██║██║  ██║   ██║   ███████╗██║██████╔╝${RESET}"
        echo -e "${PURPLE}  ╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝   ╚══════╝╚═╝╚═════╝ ${RESET}"
        echo -e "${CYAN}           new project wizard v${VERSION}${RESET}"
        echo ""

        while true; do
            echo -ne "${CYAN}?${RESET} Project name: "
            read PROJECT_NAME
            if [[ -z "$PROJECT_NAME" ]]; then
                echo -e "${RED}  ✗ Project name cannot be empty${RESET}"
            elif [[ "$PROJECT_NAME" =~ [^a-zA-Z0-9_-] ]]; then
                echo -e "${RED}  ✗ No spaces or special characters allowed${RESET}"
            else
                break
            fi
        done

        if [ "$DEFAULT_LANG" = "c" ]; then LANG_DEF_CHOICE="2"; else LANG_DEF_CHOICE="1"; fi
        echo -e "${CYAN}?${RESET} Project Language:"
        echo -e "  ${YELLOW}1)${RESET} C++ (g++)"
        echo -e "  ${YELLOW}2)${RESET} C   (gcc)"
        echo -ne "  Choice ${YELLOW}[$LANG_DEF_CHOICE]${RESET}: "
        read LANG_CHOICE
        LANG_CHOICE=${LANG_CHOICE:-$LANG_DEF_CHOICE}
        
        if [ "$LANG_CHOICE" = "2" ]; then
            EXT="c"
            COMPILER="gcc"
            LANG_NAME="C"
        else
            EXT="cpp"
            COMPILER="g++"
            LANG_NAME="C++"
        fi

        check_dependency "$COMPILER"

        echo -ne "${CYAN}?${RESET} Project location ${YELLOW}[$DEFAULT_LOC]${RESET}: "
        read PROJECT_LOC
        PROJECT_LOC=${PROJECT_LOC:-$DEFAULT_LOC}
        PROJECT_LOC="${PROJECT_LOC/#\~/$HOME}"
        FULL_PATH="$PROJECT_LOC/$PROJECT_NAME"

        if [ -d "$FULL_PATH" ]; then
            echo -e "${RED}  ✗ Directory already exists: $FULL_PATH${RESET}"
            exit 1
        fi

        echo -ne "${CYAN}?${RESET} Window title ${YELLOW}[$PROJECT_NAME]${RESET}: "
        read WIN_TITLE
        WIN_TITLE=${WIN_TITLE:-$PROJECT_NAME}

        echo -e "${CYAN}?${RESET} Resolution:"
        echo -e "  ${YELLOW}1)${RESET} 800x600"
        echo -e "  ${YELLOW}2)${RESET} 1920x1080"
        echo -e "  ${YELLOW}3)${RESET} ${DEFAULT_WIDTH}x${DEFAULT_HEIGHT} (your default)"
        echo -e "  ${YELLOW}4)${RESET} Custom"
        echo -ne "  Choice ${YELLOW}[3]${RESET}: "
        read RES_CHOICE
        case $RES_CHOICE in
            1) WIDTH=800; HEIGHT=600 ;;
            2) WIDTH=1920; HEIGHT=1080 ;;
            4)
                echo -ne "${CYAN}?${RESET} Width: "
                read WIDTH
                echo -ne "${CYAN}?${RESET} Height: "
                read HEIGHT
                ;;
            *) WIDTH=$DEFAULT_WIDTH; HEIGHT=$DEFAULT_HEIGHT ;;
        esac

        echo -ne "${CYAN}?${RESET} Target FPS ${YELLOW}[$DEFAULT_FPS]${RESET}: "
        read FPS
        FPS=${FPS:-$DEFAULT_FPS}

        echo ""
        echo -e "${PURPLE}  Creating project...${RESET}"
        echo -e "  ${CYAN}Name:${RESET}        $PROJECT_NAME"
        echo -e "  ${CYAN}Language:${RESET}    $LANG_NAME"
        echo -e "  ${CYAN}Path:${RESET}        $FULL_PATH"
        echo -e "  ${CYAN}Window:${RESET}      $WIN_TITLE"
        echo -e "  ${CYAN}Resolution:${RESET} ${WIDTH}x${HEIGHT}"
        echo -e "  ${CYAN}FPS:${RESET}         $FPS"
        echo ""

        mkdir -p "$FULL_PATH/.vscode"
        mkdir -p "$FULL_PATH/build"

        cat > "$FULL_PATH/main.$EXT" << CPPEOF
#include "raylib.h"

int screen_width = $WIDTH;
int screen_height = $HEIGHT;

int main(void) {
    InitWindow(screen_width, screen_height, "$WIN_TITLE");
    SetTargetFPS($FPS);

    while (!WindowShouldClose()) {
        BeginDrawing();
        ClearBackground(RAYWHITE);

        EndDrawing();
    }

    CloseWindow();
    return 0;
}
CPPEOF

        cat > "$FULL_PATH/build.sh" << SHELLBUILD
#!/bin/bash
mkdir -p build
echo "Compiling main.$EXT..."
$COMPILER main.$EXT -o build/$PROJECT_NAME -lraylib -lm -ldl -lpthread -lGL -lX11
if [ \$? -eq 0 ]; then
    echo "Running build/$PROJECT_NAME..."
    ./build/$PROJECT_NAME
else
    echo "Compilation failed."
fi
SHELLBUILD
        chmod +x "$FULL_PATH/build.sh"

        cat > "$FULL_PATH/.vscode/tasks.json" << TASKEOF
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Raylib: Build & Run Game",
      "type": "shell",
      "command": "./build.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always",
        "focus": true
      }
    }
  ]
}
TASKEOF

        cat > "$FULL_PATH/.vscode/settings.json" << SETTINGSEOF
{
  "code-runner.executorMap": {
    "cpp": "cd \${workspaceFolder} && ./build.sh",
    "c": "cd \${workspaceFolder} && ./build.sh"
  },
  "C_Cpp.default.configurationProvider": "ms-vscode.cpptools"
}
SETTINGSEOF

        echo -e "${GREEN}  ✓ Project successfully created at $FULL_PATH${RESET}"
        echo ""
        
        if command -v code &> /dev/null; then
            echo -ne "${CYAN}  Open in VSCode? ${YELLOW}[Y/n]${RESET}: "
            read OPEN_CODE
            if [[ "$OPEN_CODE" != "n" && "$OPEN_CODE" != "N" ]]; then
                code "$FULL_PATH"
            fi
        else
            echo -e "${YELLOW}  ℹ VSCode CLI interface ('code') not found in PATH. Skipping open step.${RESET}"
        fi

        echo ""
        echo -e "${GREEN}  ✓ Done! Ensure you open the FOLDER in VSCode, then press Ctrl+Shift+B.${RESET}"
        echo -e "  ${YELLOW}Tip:${RESET} You can also run ${CYAN}./build.sh${RESET} straight from the project terminal."
        echo ""
        ;;

    config)
        echo ""
        echo -e "${PURPLE}  ██████╗ ██╗     ██████╗██╗     ██╗${RESET}"
        echo -e "${PURPLE}  ██╔══██╗██║    ██╔════╝██║     ██║${RESET}"
        echo -e "${PURPLE}  ██████╔╝██║    ██║     ██║     ██║${RESET}"
        echo -e "${PURPLE}  ██╔══██╗██║    ██║     ██║     ██║${RESET}"
        echo -e "${PURPLE}  ██║  ██║███████╗╚██████╗███████╗██║${RESET}"
        echo -e "${PURPLE}  ╚═╝  ╚═╝╚══════╝ ╚═════╝╚══════╝╚═╝${RESET}"
        echo -e "${CYAN}          global defaults editor${RESET}"
        echo ""

        mkdir -p "$CONFIG_DIR"

        echo -ne "${CYAN}?${RESET} Default project location ${YELLOW}[$DEFAULT_LOC]${RESET}: "
        read NEW_LOC
        NEW_LOC=${NEW_LOC:-$DEFAULT_LOC}

        if [ "$DEFAULT_LANG" = "c" ]; then CONF_LANG_DEF="2"; else CONF_LANG_DEF="1"; fi
        echo -e "${CYAN}?${RESET} Default Language:"
        echo -e "  ${YELLOW}1)${RESET} C++"
        echo -e "  ${YELLOW}2)${RESET} C"
        echo -ne "  Choice ${YELLOW}[$CONF_LANG_DEF]${RESET}: "
        read NEW_LANG_CHOICE
        NEW_LANG_CHOICE=${NEW_LANG_CHOICE:-$CONF_LANG_DEF}
        if [ "$NEW_LANG_CHOICE" = "2" ]; then NEW_LANG="c"; else NEW_LANG="cpp"; fi

        echo -ne "${CYAN}?${RESET} Default window width ${YELLOW}[$DEFAULT_WIDTH]${RESET}: "
        read NEW_WIDTH
        NEW_WIDTH=${NEW_WIDTH:-$DEFAULT_WIDTH}

        echo -ne "${CYAN}?${RESET} Default window height ${YELLOW}[$DEFAULT_HEIGHT]${RESET}: "
        read NEW_HEIGHT
        NEW_HEIGHT=${NEW_HEIGHT:-$DEFAULT_HEIGHT}

        echo -ne "${CYAN}?${RESET} Default target FPS ${YELLOW}[$DEFAULT_FPS]${RESET}: "
        read NEW_FPS
        NEW_FPS=${NEW_FPS:-$DEFAULT_FPS}

        cat > "$CONFIG_FILE" << CONFEOF
DEFAULT_LOC="$NEW_LOC"
DEFAULT_WIDTH=$NEW_WIDTH
DEFAULT_HEIGHT=$NEW_HEIGHT
DEFAULT_FPS=$NEW_FPS
DEFAULT_LANG="$NEW_LANG"
CONFEOF

        echo ""
        echo -e "${GREEN}  ✓ Defaults successfully saved to $CONFIG_FILE${RESET}"
        echo ""
        ;;

    help|-h|--help)
        echo ""
        echo -e "${PURPLE}rlcli${RESET} - An interactive project manager for Raylib (C/C++)"
        echo ""
        echo -e "${CYAN}Usage:${RESET}"
        echo -e "  rlcli [command]"
        echo ""
        echo -e "${CYAN}Commands:${RESET}"
        echo -e "  ${YELLOW}new${RESET}               Launch the project setup wizard"
        echo -e "  ${YELLOW}config${RESET}            Modify your global fallback choices (Language, Res, Path)"
        echo -e "  ${YELLOW}version, -v${RESET}       Display current tool release version"
        echo -e "  ${YELLOW}help, -h, --help${RESET}  Display this instructional panel"
        echo ""
        ;;

    version|-v|--version)
        echo -e "${CYAN}rlcli version ${VERSION}${RESET}"
        ;;

    *)
        echo ""
        echo -e "${RED}  ✗ Unknown command: $1${RESET}"
        echo -e "  Usage: ${CYAN}rlcli [new | config | help | version]${RESET}"
        echo ""
        exit 1
        ;;
esac
